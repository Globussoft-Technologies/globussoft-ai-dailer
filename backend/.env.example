# ══════════════════════════════════════════════════════════════════════════════
# Callified AI — Go Backend Environment Template
# Copy to .env and fill in real values.
# For Docker Compose: this file is loaded via env_file in docker-compose.yml
# For bare-metal dev: copy to .env and set MYSQL_HOST=127.0.0.1
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
GO_AUDIO_PORT=8001
PUBLIC_SERVER_URL=https://your-domain.com    # Base URL for Twilio/Exotel callbacks + TwiML
APP_URL=https://your-domain.com              # Frontend URL used in email links

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql                             # Docker service name; use 127.0.0.1 for bare-metal
MYSQL_USER=callified
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=callified_ai
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@redis:6379/1
REDIS_PASSWORD=your_redis_password

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key           # Must match Python service key during migration period

# ── LLM Providers ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini                          # gemini | groq
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── RAG Service ───────────────────────────────────────────────────────────────
RAG_SERVICE_URL=http://rag-service:8002      # Internal Docker service URL (Phase 5+)

# ── Speech-to-Text ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Text-to-Speech ────────────────────────────────────────────────────────────
TTS_PROVIDER=smallest                        # smallest | elevenlabs | sarvam
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
SMALLEST_API_KEY=your_smallest_api_key
SMALLEST_VOICE_ID=emily
SARVAM_API_KEY=your_sarvam_api_key

# ── Telephony ─────────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=exotel                      # twilio | exotel

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Exotel
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_CALLER_ID=your_exotel_caller_id
EXOTEL_APP_ID=1210468

# ── WhatsApp Providers ────────────────────────────────────────────────────────
# Per-org credentials are stored in the database (wa_channel_configs table).
# These are global fallbacks / webhook verification tokens:
META_WHATSAPP_VERIFY_TOKEN=your_meta_verify_token
GUPSHUP_APP_KEY=your_gupshup_app_key
WATI_API_KEY=your_wati_api_key

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password              # Gmail App Password (not account password)
SMTP_FROM_NAME=Callified AI

# ── Recordings ────────────────────────────────────────────────────────────────
RECORDINGS_DIR=/recordings                   # Docker volume mount path
