# ── Copy this file to .env.docker and fill in real values ────────────────────
# For local bare-metal dev, copy to .env and set MYSQL_HOST=127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_HOST=db
MYSQL_USER=callified
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=callified_ai
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@redis:6379/1

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key

# ── Server URL ────────────────────────────────────────────────────────────────
PUBLIC_SERVER_URL=http://localhost:8001
APP_URL=http://localhost:8001

# ── LLM Providers ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Speech-to-Text ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Text-to-Speech ────────────────────────────────────────────────────────────
TTS_PROVIDER=smallest
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
SMALLEST_API_KEY=your_smallest_api_key
SMALLEST_VOICE_ID=emily
SARVAM_API_KEY=your_sarvam_api_key

# ── Telephony ─────────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=exotel
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_CALLER_ID=your_exotel_caller_id
EXOTEL_APP_ID=your_exotel_app_id
